{
  "name": "@pkg/trpc",
  "version": "0.1.0",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas.js",
      "require": "./dist/schemas.js",
      "types": "./dist/schemas.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/client.js",
      "require": "./dist/errors/client.js",
      "types": "./dist/errors/client.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "prebuild": "pnpm run clean"
  },
  "dependencies": {
    "@pkg/schema": "workspace:*",
    "@pkg/utils": "workspace:*",
    "@pkg/auth": "workspace:*",
    "@pkg/db": "workspace:*",
    "@trpc/server": "^11.7.2",
    "drizzle-orm": "^0.44.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "rimraf": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
